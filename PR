#!/bin/bash
########################################################
# script name  : table_size_tracker.sh
# Description  : Reads parent + child metadata, probes HDFS
#                sizes, classifies into buckets and writes to:
#                1. Flat cfg file  -> fast runtime awk lookup
#                2. Hive table     -> governance + history
# Developer    : FDP Ingestion Team
# Developed on : March 2026
# Usage        : sh table_size_tracker.sh <<ENV>> <<FDP_DIR>>
########################################################
source ~/.bashrc
export SPARK_MAJOR_VERSION=3
set +u

env=$1
FDP_DIR=$2

PARENT_META="${FDP_DIR}/metadata_upload/ingestion_metadata/parent_metadata.csv"
METADATA_DIR="${FDP_DIR}/metadata_upload/ingestion_metadata"
OUTPUT_CFG="${FDP_DIR}/ingestion/param/table_size_bucket.cfg"
TEMP_CFG="${OUTPUT_CFG}.tmp"
source ${FDP_DIR}/config/ingestion_config.env
# fdp_df_metadata_info_ prefix is specific to this registry DB — no equivalent in ingestion_config.env
HIVE_META_DB="fdp_df_metadata_info_${env}"
REGISTRY_TABLE="${HIVE_META_DB}.table_size_registry"
STAGING_TABLE="${HIVE_META_DB}.tmp_registry_load_stg"
# TEMP_HDFS_PATH sourced from ingestion_config.env
STAGING_HDFS="${TEMP_HDFS_PATH}/${HIVE_META_DB}/tmp_registry_load_stg"
PREPROCESSING_DIR="${FDP_DIR}/ingestion/scripts/preprocessing"
mkdir -p "${PREPROCESSING_DIR}"
> ${PREPROCESSING_DIR}/registry_data.csv
loginfo() { echo "$(date +'%Y/%m/%d %H:%M:%S') : INFO : $1"; }
logerr()  { echo "$(date +'%Y/%m/%d %H:%M:%S') : ERROR : $1"; exit 1; }

[ -z "${env}" ]           && logerr "ENV argument required"
[ -z "${FDP_DIR}" ]       && logerr "FDP_DIR argument required"
[ ! -f "${PARENT_META}" ] && logerr "Parent metadata not found: ${PARENT_META}"

loginfo "Starting table_size_tracker | env=${env}"
loginfo "Parent metadata : ${PARENT_META}"
loginfo "Output cfg file : ${OUTPUT_CFG}"
loginfo "Hive table      : ${REGISTRY_TABLE}"

#
# STEP 1: Create Hive registry table if not exists
# ORC chosen: FDP standard for Hive metadata tables; queried only via Hive;
# no ACID operations needed (transactional=false)
#
loginfo "Ensuring Hive registry table exists..."
hive -e "
CREATE TABLE IF NOT EXISTS ${REGISTRY_TABLE} (
    table_file_id        STRING,
    source_table_name    STRING,
    brnz_src_schema      STRING,
    brnz_src_table       STRING,
    hdfs_path            STRING,
    source               STRING,
    tp                   STRING,
    size_gb              FLOAT,
    bucket               STRING,
    run_date             STRING,
    last_updated         TIMESTAMP,
    country              STRING
)
STORED AS ORC
TBLPROPERTIES ('transactional'='false');" 2>/dev/null

loginfo "Hive table ready."

#
# STEP 2: Build child metadata lookup
#         table_file_id -> brnz_src_schema | brnz_src_table_name
#         Reads ALL *_child_metadata.csv files (one per tpsys)
#
loginfo "Building child metadata lookup from all *_child_metadata.csv files..."
CHILD_LOOKUP="${PREPROCESSING_DIR}/child_lookup_${env}_$$.tmp"
> ${CHILD_LOOKUP}

for child_file in ${METADATA_DIR}/*child_metadata.csv; do
    [ ! -f "${child_file}" ] && continue
    # child file fields: table_file_id|brnz_src_table_schema|brnz_src_table_name|...
    # f1=table_file_id | f2=brnz_src_table_schema | f3=brnz_src_table_name
    # Keep only FIRST occurrence per table_file_id (skip duplicate column rows)
    tail -n +2 "${child_file}" \
        | awk -F'|' 'seen[$1]++ == 0 {print $1 "|" $2 "|" $3 "|" $11}' \
        >> ${CHILD_LOOKUP}
done

loginfo "Child lookup ready: $(wc -l < ${CHILD_LOOKUP}) unique table_ids"

#
# STEP 3: Write cfg file header
#
echo "# Auto-generated by table_size_tracker.sh - do not edit manually" > ${TEMP_CFG}
echo "# Source : ${PARENT_META}"                                         >> ${TEMP_CFG}
echo "# Generated : $(date +'%Y-%m-%d %H:%M:%S')"                       >> ${TEMP_CFG}
echo "# Format : table_file_id|country|bucket|size_gb|run_date"         >> ${TEMP_CFG}
echo "# Buckets: SMALL(<5GB) | MEDIUM(<50GB) | LARGE(<200GB) | XL"     >> ${TEMP_CFG}

#
# STEP 4: Main loop
#    - Read parent_metadata row by row
#    - Join with child lookup for brnz table name
#    - Probe HDFS for real size
#    - Classify into bucket
#    - Write to cfg file AND Hive table
#
processed=0
failed=0
run_date=$(date +%Y-%m-%d)
run_ts=$(date +'%Y-%m-%d %H:%M:%S')

# Calculate last 3 COBS dates dynamically
# prd  : compute last 3 consecutive month-end dates (existing logic - unchanged)
# !prd : query actual available run_dates from registry
#         - avoids assuming consecutive month-ends that may not exist in non-prod
#         - if registry is empty (first run), COBS_DATES is empty string
get_last_3_cobs_dates() {
    if [ "${env}" = "prd" ]; then
        # Production: compute last 3 consecutive month-end dates
        local result=()
        local y=$(date +%Y)
        local m=$(date +%m)
        for i in 1 2 3; do
            m=$(( (10#$m - 1) ))
            if [ $m -eq 0 ]; then m=12; y=$((y - 1)); fi
            local last_day=$(date -d "${y}-$(printf '%02d' $m)-01 +1 month -1 day" +%Y-%m-%d)
            result+=("$last_day")
        done
        echo "${result[@]}"
    else
        # Non-prod: only use dates that actually have data in registry
        # Do NOT assume consecutive month-ends - query actual available partitions
        hive -e "SELECT DISTINCT run_date FROM ${REGISTRY_TABLE} \
                 ORDER BY run_date DESC LIMIT 3;" 2>/dev/null \
        | grep -E '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' \
        | tr '\n' ' '
    fi
}

COBS_DATES=$(get_last_3_cobs_dates)
loginfo "Last 3 COBS dates: ${COBS_DATES}"

# PRE-BUILD HDFS size lookup - one hadoop call per schema
# loginfo "Pre-building HDFS size lookup (~5 mins)..."
# HDFS_SIZE_LOOKUP="/tmp/hdfs_size_lookup.txt"
# > "${HDFS_SIZE_LOOKUP}"

# awk -F'|' '{print $2}' ${PREPROCESSING_DIR}/child_lookup_${env}_*.tmp \
#    | grep -v '^$' | sort -u > ${PREPROCESSING_DIR}/schema_list.tmp
# while IFS= read -r schema; do
#    schema_lower=$(echo "${schema}" | tr 'A-Z' 'a-z')
#    hadoop fs -du "/sit_enc/fdp/bank/hdata/fdp_dev/${schema_lower}_${env}/" \
#        2>/dev/null >> "${HDFS_SIZE_LOOKUP}"
# done < ${PREPROCESSING_DIR}/schema_list.tmp

# loginfo "Size lookup ready: $(wc -l < ${HDFS_SIZE_LOOKUP}) entries"

# HDFS_SIZE_LOOKUP is a pre-built external input file - path kept as /tmp by convention
HDFS_SIZE_LOOKUP="/tmp/hdfs_size_lookup.txt"
loginfo "Using pre-built HDFS size lookup: ${HDFS_SIZE_LOOKUP}"

# Pre-build parent metadata lookup
# # Format: table_file_id|country|hdfs_nas_path|source|tp
# PARENT_LOOKUP="${PREPROCESSING_DIR}/parent_lookup_${env}.tmp"
# awk -F'|' 'NR>1 {print $1"|"$3"|"$6"|"$2"|"$4}' ${PARENT_META} > ${PARENT_LOOKUP}
# loginfo "Parent lookup ready: $(wc -l < ${PARENT_LOOKUP}) entries"

# Pre-fetch max size_gb per table_file_id across last 3 COBS dates
# Format: table_file_id|max_size_gb
COBS_LOOKUP="${PREPROCESSING_DIR}/cobs_size_lookup_${env}.tmp"

# Guard: only run COBS prefetch if dates are available in registry
# If COBS_DATES is empty (first run / empty registry), create empty COBS_LOOKUP
# and all tables will fall back to HDFS_SIZE_LOOKUP - same behaviour as pre-COBS
if [ -n "${COBS_DATES}" ]; then
    COBS_IN=$(echo "${COBS_DATES}" | tr ' ' '\n' \
        | awk '{print "\x27"$0"\x27"}' | paste -sd',')

    loginfo "Pre-fetching COBS size data for dates: ${COBS_DATES}..."
    hive -e "
    SELECT table_file_id, MAX(size_gb)
    FROM ${REGISTRY_TABLE}
    WHERE run_date IN (${COBS_IN})
    GROUP BY table_file_id;" 2>/dev/null \
    | grep -v "^$" | tr '\t' '|' > ${COBS_LOOKUP}

    loginfo "COBS lookup ready: $(wc -l < ${COBS_LOOKUP}) tables"
else
    loginfo "No COBS data in registry for env=${env} - falling back to HDFS size for all tables"
    > ${COBS_LOOKUP}
fi

while IFS='|' read -r \
    table_file_id source country tp source_table_name \
    hdfs_nas_path rest_fields; do

    # - Lookup child metadata for this table_file_id --------
    # Matches on f1 (table_file_id) - same join key used in
    # read_child_metadata() in fdp_staging_loader_functions.sh
    child_row=$(grep "^${table_file_id}|" ${CHILD_LOOKUP} | head -1)
    # parent_row=$(grep "^${table_file_id}|" ${PARENT_LOOKUP} | head -1)
    # country=$(echo "${parent_row}" | cut -d'|' -f2)

    # hdfs_nas_path=$(echo "${parent_row}" | cut -d'|' -f3)
    # source=$(echo "${parent_row}" | cut -d'|' -f4)
    # tp=$(echo "${parent_row}" | cut -d'|' -f5)
    brnz_schema=$(echo "${child_row}" | cut -d'|' -f2)
    brnz_table=$(echo "${child_row}" | cut -d'|' -f3)
    brnz_tgt_table_schema=$(echo "${child_row}" | cut -d'|' -f4 | tr '[:upper:]' '[:lower:]')
    if [ -z "${brnz_tgt_table_schema}" ]; then
        echo "${table_file_id}|${country}|UNKNOWN|-1|${run_date}" >> ${TEMP_CFG}
        continue
    fi
    brnz_tgt_table_schema="${brnz_tgt_table_schema}_${env}"
    brnz_table=$(echo "${child_row}" | cut -d'|' -f12)
    brnz_table_lower=$(echo "${brnz_table}" | tr '[:upper:]' '[:lower:]')

    # - Skip rows with no HDFS path -
    #    if [ -z "${hdfs_nas_path}" ] || [ "${hdfs_nas_path}" = " " ]; then
    #    brnz_tgt_lower=$(echo "${brnz_tgt_table_schema}" | tr '[:upper:]' '[:lower:]')
    #    brnz_table_lower=$(echo "${brnz_table}" | tr '[:upper:]' '[:lower:]')

    #    if [ -z "${brnz_tgt_lower}" ] || [ -z "${brnz_table_lower}" ]; then
    #        echo "${table_file_id}|UNKNOWN|-1|${run_date}" >> ${TEMP_CFG}
    #        continue
    #    fi

    # - Build HDFS path from schema/table name
    #   hdfs_path sourced from ingestion_config.env (e.g. /sit_enc/fdp/bank/hdata/fdp_dev/)
    hdfs_table_path="${hdfs_path}${brnz_tgt_table_schema}/${brnz_table_lower}_"

    # raw_bytes=$(grep -iF "/${brnz_tgt_table_schema}_dev}.${brnz_table_lower}_" \
    #raw_bytes=$(grep -iF "${brnz_tgt_table_schema}" "${HDFS_SIZE_LOOKUP}" | head -1| awk '{print $1}')

    # Try COBS registry first
    cobs_size_gb=$(grep "^${table_file_id}|" "${COBS_LOOKUP}" \
    | head -1 | cut -d'|' -f2)

    if [ -n "${cobs_size_gb}" ] && [ "${cobs_size_gb}" != "NULL" ]; then
        # Convert GB back to bytes for existing bucket logic
        raw_bytes=$(echo "scale=0; ${cobs_size_gb} * 1073741824 / 1" | bc)
        loginfo "table_id=${table_file_id} | COBS size: ${cobs_size_gb}GB"
    else
        # Fallback: current HDFS size (first run before COBS data exists)
        raw_bytes=$(grep -iF "/${brnz_tgt_table_schema}" \
            "${HDFS_SIZE_LOOKUP}" | head -1 | awk '{print $1}')
        loginfo "table_id=${table_file_id} | no COBS data, fallback to HDFS"
    fi

    if [ -z "${raw_bytes}" ]; then
        loginfo "WARN table_id=${table_file_id} | not found in size lookup | ${hdfs_table_path}"
        size_gb="-1"
        bucket="UNKNOWN"
        failed=$(( failed + 1 ))
        continue
    fi

    # - Probe actual HDFS size --------------------------------
    # Same hdfs command pattern used in rest of FDP codebase
    # raw_bytes=$(hdfs dfs -du -s "${hdfs_nas_path}" 2>/dev/null | awk '{print $1}')

    if [ -z "${raw_bytes}" ]; then
        loginfo "WARN table_id=${table_file_id} | HDFS probe failed: ${hdfs_table_path}"
        size_gb="-1"
        bucket="UNKNOWN"
        failed=$((failed + 1))
    else
        size_gb=$(echo "scale=4; ${raw_bytes} / 1073741824" | bc)
        size_int=$(echo ${size_gb} | cut -d'.' -f1)
        # Default to 0 if empty to avoid falling through to XL bucket
        size_int=${size_int:-0}

        if   [ "${size_int}" -lt 5   ] 2>/dev/null; then bucket="SMALL"
        elif [ "${size_int}" -lt 50  ] 2>/dev/null; then bucket="MEDIUM"
        elif [ "${size_int}" -lt 200 ] 2>/dev/null; then bucket="LARGE"
        else                                              bucket="XL"
        fi
    fi

    loginfo "table_id=${table_file_id} | src=${source_table_name} | brnz=${brnz_table} | ${size_gb}GB | ${bucket}"

    # - OUTPUT 1: Flat cfg file -------------------------------
    # Used by get_spark_config_for_table() via awk at runtime
    # Same pattern as dynamic_partition_string.cfg
    echo "${table_file_id}|${country}|${bucket}|${size_gb}|${run_date}" >> ${TEMP_CFG}

    # - OUTPUT 2: Hive table ----------------------------------
    # Full record with table_name, schema, path for governance
    echo "${table_file_id}|${source_table_name}|${brnz_schema}|${brnz_table}|${hdfs_nas_path}|${source}|${tp}|${size_gb}|${country}|${bucket}|${run_date}|${run_ts}" >> ${PREPROCESSING_DIR}/registry_data.csv

    processed=$((processed + 1))
done < <(tail -n +2 "${PARENT_META}")

# loginfo "Loading data into Hive registry..."
# timeout 300 hive 2>/dev/null <<EOF || true
# CREATE TEMPORARY TABLE tmp_registry_load (
#     table_file_id STRING, source_table_name STRING, brnz_src_schema STRING,
#     brnz_src_table STRING, hdfs_path STRING, source STRING, tp STRING,
#     size_gb FLOAT, bucket STRING, run_date STRING, run_ts TIMESTAMP
# ) ROW FORMAT DELIMITED FIELDS TERMINATED BY '|';
# LOAD DATA LOCAL INPATH '${PREPROCESSING_DIR}/registry_data.csv' OVERWRITE INTO TABLE tmp_registry_load;
# INSERT OVERWRITE TABLE ${REGISTRY_TABLE} SELECT * FROM tmp_registry_load;
# EOF
# loginfo "Hive bulk load complete."

# --- Registry HDFS load (replaces beeline LOAD DATA LOCAL) ---
hive -e "
DROP TABLE IF EXISTS ${STAGING_TABLE};
CREATE TABLE ${STAGING_TABLE} (
    table_file_id STRING, source_table_name STRING, brnz_src_schema STRING,
    brnz_src_table STRING, hdfs_path STRING, source STRING, tp STRING,
    size_gb STRING, country STRING, bucket STRING, run_date STRING, last_updated STRING
)
ROW FORMAT DELIMITED FIELDS TERMINATED BY '|'
STORED AS TEXTFILE;
" 2>>${PREPROCESSING_DIR}/hive_load_err.log

hadoop fs -put -f ${PREPROCESSING_DIR}/registry_data.csv ${STAGING_HDFS}/registry_data.csv

hive -e "
INSERT OVERWRITE TABLE ${REGISTRY_TABLE}
SELECT table_file_id, source_table_name, brnz_src_schema, brnz_src_table,
       hdfs_path, source, tp, CAST(size_gb AS FLOAT),
       CAST(last_updated AS TIMESTAMP), country,
       bucket, run_date
FROM ${STAGING_TABLE};
DROP TABLE IF EXISTS ${STAGING_TABLE};
" 2>>${PREPROCESSING_DIR}/hive_load_err.log

loginfo "Hive load complete. Errors (if any) logged to ${PREPROCESSING_DIR}/hive_load_err.log"

#
# STEP 5: Atomic replace of cfg file
#         mv is atomic on same filesystem - prevents partial
#         reads by concurrent ingestion runs
#
mv ${TEMP_CFG} ${OUTPUT_CFG}

loginfo "===== TABLE SIZE TRACKER COMPLETE ====="
loginfo "Processed     : ${processed}"
loginfo "Failed probes : ${failed}"
loginfo "Cfg file      : ${OUTPUT_CFG}"
loginfo "Hive table    : ${REGISTRY_TABLE}"

#
# STEP 6: Print Hive summary for the run log
#
loginfo "Bucket distribution for run_date=${run_date}:"

hive 2>/dev/null <<EOF
SELECT bucket,
       COUNT(*)              AS table_count,
       ROUND(MIN(size_gb),2) AS min_gb,
       ROUND(AVG(size_gb),2) AS avg_gb,
       ROUND(MAX(size_gb),2) AS max_gb
FROM   ${REGISTRY_TABLE}
WHERE  run_date = '${run_date}'
GROUP BY bucket
ORDER BY bucket;
EOF

# Cleanup temp files
rm -f ${CHILD_LOOKUP}
rm -f ${COBS_LOOKUP}
# rm -f ${PARENT_LOOKUP}
